# Copy to .env and fill in. The .env file is gitignored.
OPENAI_API_KEY=sk-...
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Optional — port for the proxy server (Vite proxies /api here)
PORT=8787

# --- Accounts & storage (Supabase, used by the v3 app) ---
# From supabase.com → your project → Settings → API. The anon (public)
# key is safe for the browser; row-level security governs all data
# access. Leave blank to run v3 without accounts (UI hides itself).
# Set the same two values in the Amplify console (Hosting →
# Environment variables) for the deployed build.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
